{
  "name": "recruiter-hub-prototype",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:proxy": "node proxy/offer-events-proxy.mjs",
    "test:offer-events-contract": "node scripts/offer-events-contract-smoke.mjs",
    "open:browsers": "bash ../scripts/open-url-chrome-and-cursor-browser.sh 'http://localhost:5199/'",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "typecheck:public": "NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.public.json --noEmit",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' tsc && NODE_OPTIONS='--max-old-space-size=16384' vite build",
    "build:public": "NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.public.json && NODE_OPTIONS='--max-old-space-size=16384' vite build --config vite.config.public.ts",
    "preview": "vite preview",
    "preview:public": "vite preview --config vite.config.public.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@workday/canvas-kit-react": "14.2.37",
    "@workday/canvas-kit-react-fonts": "14.2.37",
    "@workday/canvas-tokens-web": "3.1.6",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.19.37",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
