{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "main-public.tsx",
    "pm-agent-dashboard-public.tsx",
    "vite-plugin-forbidden-imports.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "vite-env.d.ts"
  ],
  "exclude": [
    "main.tsx",
    "pm-agent-dashboard.tsx",
    "data-*.ts",
    "*-dashboard.tsx",
    "*-dashboard-*.tsx",
    "value-realization-metrics.tsx",
    "recruiting-metric-tree.tsx",
    "view-dashboard.tsx",
    "offers-dashboard-v01.tsx",
    "offers-playground-v01.tsx",
    "positions-open-vs-filled-dashboard.tsx",
    "add-documents-impact-dashboard.tsx",
    "interview-metrics-dashboard.tsx",
    "recruiter-capacity-dashboard.tsx",
    "customer-scorecard-dashboard.tsx",
    "bp-duration-dashboard.tsx",
    "avg-time-to-hire-dashboard.tsx",
    "recruiting-agency-user-dashboard.tsx",
    "recruiting-adoption-dashboard.tsx",
    "gcc-recruiter-dashboard.tsx",
    "aadhaar-adobe-sign-v01.tsx",
    "candidate-grid-v84.tsx",
    "recruiter-home-v85.tsx",
    "candidate-smart-view-v86.tsx",
    "india-whatsapp-candidate-messaging-v88.tsx",
    "gcc-interview-scheduling-compliance-nudges-v90.tsx",
    "gcc-candidate-grid-search.tsx",
    "recruiter-hub-genui-v95.tsx",
    "recruiter-hub-conversational-v98.tsx",
    "recruiter-hub-conversational-v99.tsx",
    "india-native-whatsapp-v91.tsx",
    "interview-intelligence-agent-v96.tsx",
    "ai-system-of-record-v97.tsx",
    "universal-profile-eudi-wallet-v1.tsx",
    "node_modules",
    "dist",
    "dashboard-public-dist"
  ]
}
