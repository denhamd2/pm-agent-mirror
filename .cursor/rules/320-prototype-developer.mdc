// /src/components/TimesheetApproval/TimesheetApproval.tsx
import React, { useState } from 'react';
import { PrimaryButton, SecondaryButton } from '@workday/canvas-kit-react/button';
import { Table, TableRow, TableCell } from '@workday/canvas-kit-react/table';
import { Select } from '@workday/canvas-kit-react/select';
import { Banner } from '@workday/canvas-kit-react/banner';
import { space } from '@workday/canvas-kit-react/tokens';

interface TimesheetApprovalProps {
  timesheets: Timesheet[];
  onApprove: (ids: string[]) => Promise<void>;
  onReject: (ids: string[]) => Promise<void>;
}

export const TimesheetApproval: React.FC<TimesheetApprovalProps> = ({
  timesheets,
  onApprove,
  onReject
}) => {
  const [filter, setFilter] = useState('all');
  const [selectedIds, setSelectedIds] = useState<string[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [success, setSuccess] = useState<string | null>(null);

  const filteredTimesheets = timesheets.filter(t => 
    filter === 'all' || t.status === filter
  );

  const handleApprove = async () => {
    setIsLoading(true);
    setError(null);
    try {
      await onApprove(selectedIds);
      setSuccess('Timesheets approved successfully');
      setSelectedIds([]);
    } catch (err) {
      setError('Unable to approve timesheets. Check your connection and try again.');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div>
      {error && (
        <Banner variant="error" onClose={() => setError(null)}>
          {error}
        </Banner>
      )}
      
      {success && (
        <Banner variant="success" onClose={() => setSuccess(null)}>
          {success}
        </Banner>
      )}

      <div style={{ marginBottom: space.m }}>
        <Select
          label="Filter by status"
          value={filter}
          onChange={(e) => setFilter(e.target.value)}
        >
          <option value="all">All</option>
          <option value="pending">Pending</option>
          <option value="approved">Approved</option>
        </Select>
      </div>

      {filteredTimesheets.length === 0 ? (
        <Banner variant="info">
          No pending timesheets. Check back later.
        </Banner>
      ) : (
        <>
          <Table>
            <thead>
              <TableRow>
                <TableCell>Employee</TableCell>
                <TableCell>Week</TableCell>
                <TableCell>Hours</TableCell>
                <TableCell>Status</TableCell>
              </TableRow>
            </thead>
            <tbody>
              {filteredTimesheets.map(timesheet => (
                <TableRow key={timesheet.id}>
                  <TableCell>{timesheet.employeeName}</TableCell>
                  <TableCell>{timesheet.week}</TableCell>
                  <TableCell>{timesheet.hours}</TableCell>
                  <TableCell>{timesheet.status}</TableCell>
                </TableRow>
              ))}
            </tbody>
          </Table>

          <div style={{ display: 'flex', gap: space.s, marginTop: space.m }}>
            <PrimaryButton 
              onClick={handleApprove} 
              disabled={selectedIds.length === 0 || isLoading}
            >
              {isLoading ? 'Approving...' : 'Approve'}
            </PrimaryButton>
            <SecondaryButton 
              onClick={handleReject} 
              disabled={selectedIds.length === 0 || isLoading}
            >
              Reject
            </SecondaryButton>
          </div>
        </>
      )}
    </div>
  );
};
```

