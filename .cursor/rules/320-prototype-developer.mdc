  <Routes>
    <Route path="/" element={<Dashboard />} />
    <Route path="/candidates" element={<CandidateList />} />
    <Route path="/candidates/:id" element={<CandidateDetail />} />
  </Routes>
</BrowserRouter>
```

**Example: Multi-Step Candidate Application Flow**

**User Story**: "As a candidate, I want to apply for a job through a guided 3-step process"

**Flow**: Personal Info → Work History → Review & Submit

**Implementation**:
1. Extract Figma design tokens for form styling
2. Build wizard with 3 steps using Tabs component
3. Persist form data across steps (useState or context)
4. Validate each step before allowing "Next"
5. Show summary on Step 3
6. Success message after submit

**Code structure**:
```tsx
export const CandidateApplicationWizard = () => {
  const [currentStep, setCurrentStep] = useState(1);
  const [formData, setFormData] = useState({
    personalInfo: {},
    workHistory: [],
    submitted: false
  });

  const handleNext = () => {
    if (validateCurrentStep()) {
      setCurrentStep(currentStep + 1);
    }
  };

  return (
    <Box padding="xl" maxWidth="800px" margin="0 auto">
      {/* Progress indicator styled as stepper */}
      <Flex marginBottom="l" gap="m">
        <StepIndicator number={1} label="Personal Info" active={currentStep === 1} completed={currentStep > 1} />
        <StepIndicator number={2} label="Work History" active={currentStep === 2} completed={currentStep > 2} />
        <StepIndicator number={3} label="Review" active={currentStep === 3} completed={false} />
      </Flex>

      <Card padding="l">
        {currentStep === 1 && <PersonalInfoStep data={formData.personalInfo} onChange={...} />}
        {currentStep === 2 && <WorkHistoryStep data={formData.workHistory} onChange={...} />}
        {currentStep === 3 && <ReviewStep data={formData} />}
      </Card>

      <Flex justifyContent="space-between" marginTop="l">
        <SecondaryButton onClick={() => setCurrentStep(currentStep - 1)} disabled={currentStep === 1}>
          Back
        </SecondaryButton>
        <PrimaryButton onClick={handleNext}>
          {currentStep === 3 ? 'Submit Application' : 'Next'}
        </PrimaryButton>
      </Flex>
    </Box>
  );
};
```

